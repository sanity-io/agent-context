{
  "name": "@examples/ecommerce-studio",
  "version": "1.0.0",
  "private": true,
  "license": "UNLICENSED",
  "main": "package.json",
  "scripts": {
    "build": "dotenv -e ../.env -- sanity build",
    "check:lint": "eslint .",
    "check:lint:fix": "eslint . --fix",
    "check:types": "tsc --noEmit",
    "deploy": "dotenv -e ../.env -- sanity deploy",
    "deploy-graphql": "dotenv -e ../.env -- sanity graphql deploy",
    "deploy:blueprints": "dotenv -e ../.env -- sanity blueprints deploy",
    "dev": "dotenv -e ../.env -- sanity dev",
    "dev:functions": "dotenv -e ../.env -- sanity functions dev",
    "dev:functions:logs": "dotenv -e ../.env -- sanity functions logs classify-conversations",
    "extract-schema": "dotenv -e ../.env -- sanity schema extract --path=schema.json",
    "init:blueprints": "dotenv -e ../.env -- sanity blueprints init",
    "start": "dotenv -e ../.env -- sanity start"
  },
  "prettier": "@sanity/prettier-config",
  "dependencies": {
    "@ai-sdk/anthropic": "catalog:",
    "@sanity/agent-context": "workspace:*",
    "@sanity/client": "catalog:",
    "@sanity/icons": "catalog:",
    "@sanity/ui": "catalog:",
    "@sanity/vision": "catalog:",
    "ai": "catalog:",
    "easymde": "^2.20.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-markdown": "catalog:",
    "sanity": "catalog:",
    "sanity-plugin-markdown": "^8.0.5",
    "styled-components": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@sanity/blueprints": "0.13.1",
    "@sanity/functions": "1.2.1",
    "@types/react": "catalog:",
    "dotenv-cli": "^11.0.0",
    "typescript": "catalog:"
  }
}
