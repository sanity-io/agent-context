{
  "name": "root",
  "version": "1.0.0",
  "scripts": {
    "build": "turbo build",
    "check:format": "prettier --check .",
    "check:lint": "turbo run check:lint --continue",
    "check:lint:fix": "turbo run check:lint:fix --continue",
    "check:types": "turbo run check:types",
    "dev": "turbo dev",
    "format:all": "prettier --cache --write .",
    "format:staged": "pretty-quick --staged",
    "prepare": "husky",
    "release-notes": "dotenv -e scripts/release-notes/.env -- tsx scripts/release-notes/index.ts",
    "sync-skill-example": "tsx scripts/sync-skill-example.ts",
    "test:unit": "turbo test:unit",
    "test:unit:coverage": "turbo test:unit:coverage"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*": [
      "pnpm format:staged"
    ]
  },
  "prettier": "@sanity/prettier-config",
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@portabletext/markdown": "^1.1.4",
    "@sanity/client": "^7.3.0",
    "@sanity/id-utils": "^1.0.0",
    "@sanity/prettier-config": "^3.0.0",
    "@types/node": "^22.19.15",
    "cac": "^6.7.14",
    "chalk": "^5.4.1",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "pretty-quick": "^4.2.2",
    "tsx": "^4.21.0",
    "turbo": "^2.8.15",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.29.3"
}
